# Madame Minou: required environment variables (names only, NO real values here).
# Copy this to .env and fill in. .env is gitignored and must never be committed.

# Claude Platform on AWS (the AI voice layer)
ANTHROPIC_AWS_WORKSPACE_ID=wrkspc_xxxxxxxx
AWS_REGION=us-west-2

# Auth: prefer the Lambda's IAM role (SigV4) in production.
# For local dev only, you may use an API key generated in the AWS Console
# under Claude Platform on AWS > API keys:
# ANTHROPIC_AWS_API_KEY=

# Reminders:
# - Keys live server-side only. Never ship them to the browser.
# - One-time per AWS account: aws iam enable-outbound-web-identity-federation
